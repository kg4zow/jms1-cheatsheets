###############################################################################
#
# Trim whitespace from a value without using external processes

function ltrim {
    echo "${1#"${1%%[![:space:]]*}"}"
}

function rtrim {
    echo "${1%"${1##*[![:space:]]}"}"
}

function trim {
    echo "$( ltrim "$( rtrim "$1" )" )"
}
